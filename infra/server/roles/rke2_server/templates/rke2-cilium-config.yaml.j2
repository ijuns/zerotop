apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: rke2-cilium
  namespace: kube-system
spec:
  valuesContent: |-
    operator:
      replicas: 2
    hubble:
      enabled: true
      relay:
        enabled: true
      ui:
        enabled: false
    encryption:
      enabled: true
      type: wireguard
    routingMode: tunnel
    tunnelProtocol: vxlan
    policyEnforcementMode: default

