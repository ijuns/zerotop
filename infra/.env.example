# DEVELOPMENT ONLY. Copy to infra/.env only to override Docker Compose defaults.
# The Compose topology is bound to localhost and is not a production deployment.
POSTGRES_DB=codegate
POSTGRES_USER=codegate
POSTGRES_PASSWORD=codegate_dev_only_change_me

KEYCLOAK_ADMIN=dev-admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_dev_only_change_me
KEYCLOAK_PUBLIC_URL=http://localhost:8081

# These URLs must be reachable by the host browser.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8081
ALLOWED_ORIGINS=http://localhost:3000

# Local-only Elasticsearch/Kibana. Elasticsearch security is disabled by Compose.
ELASTIC_VERSION=8.17.0
KIBANA_VERSION=8.17.0
ELASTICSEARCH_API_KEY=local_disabled_security_key

# API adapters used by the current Compose development subset.
RUNTIME_ADAPTER=simulator
RUNTIME_INTERNAL_TOKEN=runtime_dev_only_change_me
AI_ADAPTER=local
AI_APP_MODULE=app.main:app
AI_INTERNAL_TOKEN=ai_service_dev_token_change_me
TELEMETRY_INTERNAL_TOKEN=telemetry_dev_only_change_me
DESKTOP_GATEWAY_INTERNAL_TOKEN=desktop_dev_only_change_me
TARGET_IMAGE_REGISTRIES=registry.codegate.internal

# Builder, validator, grader, KubeVirt, desktop and OpenVPN services are deployed
# by Kubernetes overlays, not this local Compose file. Their full contract is in
# docs/environment-variables.md.
