# ZeroTOP local Claude configuration
#
# Use scripts/init-claude-config.ps1 to create .env.claude.local. Never put a
# real credential in this tracked example. The local file is explicitly ignored
# by Git and is read by the Claude start scripts through Docker Compose's
# --env-file option.

# The API delegates Lab generation to the isolated AI service.
AI_ADAPTER=http
AI_INTERNAL_TOKEN=REPLACE_WITH_A_DISTINCT_RANDOM_TOKEN_AT_LEAST_32_CHARS
AI_GENERATION_TIMEOUT_MS=1260000

# All learner-visible generation, independent review and free-text grading use
# the external model gateway. They fail closed when the gateway is unavailable.
AI_GENERATION_MODE=external
AI_REVIEW_MODE=external
AI_RUBRIC_MODE=external
GENERATION_PROVIDER_URL=http://model-gateway:9010/v1/generate
GENERATION_PROVIDER_TIMEOUT_SECONDS=1230
REVIEW_PROVIDER_URL=http://model-gateway:9010/v1/review
RUBRIC_PROVIDER_URL=http://model-gateway:9010/v1/rubric

# Shared only between the AI service and model gateway. Do not reuse the API
# key or AI_INTERNAL_TOKEN here.
MODEL_GATEWAY_INTERNAL_TOKEN=REPLACE_WITH_A_DISTINCT_RANDOM_TOKEN_AT_LEAST_32_CHARS
MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_API_KEY
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VERSION=2023-06-01
MODEL_GATEWAY_GENERATION_TIMEOUT_MS=1200000
MODEL_GATEWAY_GENERATION_MAX_ATTEMPTS=1
# Local one-request diagnosis only. The fixed capture file is created
# exclusively, so remove the previous container file before opting in again.
# MODEL_GATEWAY_DEBUG_RAW_RESPONSE_CAPTURE=local-explicit
MODEL_GATEWAY_REVIEW_TIMEOUT_MS=25000
MODEL_GATEWAY_RUBRIC_TIMEOUT_MS=9000
MODEL_GATEWAY_MAX_CONCURRENCY=2

# Operator-owned environment catalog. scripts/init-claude-config.ps1 resolves
# the current codegate/local-target digest instead of committing a fabricated
# one. Empty package/artifact catalogs allow ordinary prompt-based generation.
# A Lab that explicitly requests a CVE fails closed until that CVE has a reviewed
# package or artifact entry. This local-only flag allows a generic simulation
# while the catalog is empty; never enable it in production.
AI_ALLOW_UNCURATED_CVE_SIMULATION=true
AI_TARGET_BASE_IMAGE=codegate/local-target@sha256:REPLACE_WITH_CURRENT_LOCAL_IMAGE_DIGEST
AI_OUTPUT_REPOSITORY=codegate/local-target
PACKAGE_CATALOG_JSON={}
ARTIFACT_CATALOG_JSON={}

# Free-text grading policies are operator-owned and never model-authored.
RUBRIC_CATALOG_JSON={"incident-analysis-v1":{"policyVersion":"incident-analysis-2026.07","passThreshold":0.7,"criteria":[{"id":"evidence","description":"Uses concrete evidence from the isolated exercise data.","weight":0.6},{"id":"mitigation","description":"Explains a proportionate detection or mitigation action.","weight":0.4}]}}
