# Direct API/web development defaults. scripts/local-dev.ps1 sets the same safe values.
# Never reuse development identities or tokens in a deployed environment.
NODE_ENV=development
PORT=8080
AUTH_MODE=dev
REPOSITORY_MODE=sqlite
CODEGATE_DB_PATH=.data/codegate.db
SEED_DEVELOPMENT_DATA=false

RUNTIME_ADAPTER=simulator
AI_ADAPTER=local
AI_GENERATION_TIMEOUT_MS=1260000
ENVIRONMENT_BUILDER_ADAPTER=development
LAB_VALIDATOR_ADAPTER=development
GRADER_ADAPTER=mock
TELEMETRY_ADAPTER=development

CODEGATE_WEB_API_URL=http://localhost:8080
CODEGATE_WEB_KEYCLOAK_URL=http://localhost:8081
CODEGATE_WEB_KEYCLOAK_REALM=codegate
CODEGATE_WEB_KEYCLOAK_CLIENT_ID=codegate-web
CODEGATE_WEB_DEVELOPMENT_IDENTITY=true
CODEGATE_WEB_DEV_USER_ID=user_dev

# Local service URLs and development-only peer tokens.
AI_SERVICE_URL=http://localhost:8001
BUILDER_SERVICE_URL=http://localhost:9004
VALIDATOR_SERVICE_URL=http://localhost:9003
GRADER_SERVICE_URL=http://localhost:9002
RUNTIME_SERVICE_URL=http://localhost:9000
TELEMETRY_SERVICE_URL=http://localhost:9201
AI_INTERNAL_TOKEN=ai_dev_only_change_me_000000000000
BUILDER_INTERNAL_TOKEN=builder_dev_only_change_me_000000000
VALIDATOR_INTERNAL_TOKEN=validator_dev_only_change_me
GRADER_INTERNAL_TOKEN=grader_dev_only_change_me_00
RUNTIME_INTERNAL_TOKEN=runtime_dev_only_change_me_00
SANDBOX_RUNNER_INTERNAL_TOKEN=sandbox_dev_only_change_me_00
TELEMETRY_INTERNAL_TOKEN=telemetry_dev_only_change_me
DESKTOP_GATEWAY_INTERNAL_TOKEN=desktop_dev_only_change_me_00
OPENVPN_ISSUER_TOKEN=vpn_issuer_dev_only_change_me
OPENVPN_DOWNLOAD_INTERNAL_TOKEN=vpn_download_dev_only_change_me

# -----------------------------------------------------------------------------
# Production API reference. Remove the development values above, uncomment this
# section, and inject secrets from a secret manager rather than a committed file.
# -----------------------------------------------------------------------------
# NODE_ENV=production
# AUTH_MODE=oidc
# REPOSITORY_MODE=postgres
# DATABASE_URL=postgresql://REQUIRED_USER:REQUIRED_PASSWORD@REQUIRED_HOST:5432/codegate?sslmode=require
# PG_POOL_MAX=10
# SEED_DEVELOPMENT_DATA=false
# OIDC_ISSUER=https://identity.example.invalid/realms/codegate
# OIDC_JWKS_URL=https://identity.example.invalid/realms/codegate/protocol/openid-connect/certs
# OIDC_AUDIENCE=codegate-api
# OIDC_CLIENT_ID=codegate-web
# ALLOWED_ORIGINS=https://range.example.invalid
# TARGET_IMAGE_REGISTRIES=registry.example.invalid
# RUNTIME_ADAPTER=service
# AI_ADAPTER=service
# ENVIRONMENT_BUILDER_ADAPTER=service
# LAB_VALIDATOR_ADAPTER=service
# GRADER_ADAPTER=service
# TELEMETRY_ADAPTER=service
# DESKTOP_GATEWAY_PUBLIC_URL=https://desktop.example.invalid
# DESKTOP_TICKET_TTL_SECONDS=300
# OPENVPN_DOWNLOAD_PUBLIC_URL=https://vpn.example.invalid

# RUNTIME_TARGET_IMAGE is only a development template fallback. OIDC mode requires
# each validated Lab to carry its builder-produced imageRef plus imageDigest.
# RUNTIME_TARGET_IMAGE=registry.local/codegate/target:development

# AI service and provider contract.
# AI_AUTH_MODE=internal
# AI_TARGET_BASE_IMAGE=registry.example.invalid/codegate/target-bases/http-v1@sha256:REQUIRED_DIGEST
# AI_OUTPUT_REPOSITORY=registry.example.invalid/codegate/targets
# AI and builder must receive the exact same two curated catalog JSON values below.
# AI_GENERATION_MODE=external
# AI_ALLOW_UNCURATED_CVE_SIMULATION=false
# GENERATION_PROVIDER_URL=http://model-gateway:9010/v1/generate
# GENERATION_PROVIDER_TIMEOUT_SECONDS=1230
# GENERATION_PROVIDER_TOKEN=SAME_AS_MODEL_GATEWAY_INTERNAL_TOKEN
# AI_REVIEW_MODE=external
# REVIEW_PROVIDER_URL=http://model-gateway:9010/v1/review
# REVIEW_PROVIDER_TOKEN=SAME_AS_MODEL_GATEWAY_INTERNAL_TOKEN
# AI_RUBRIC_MODE=external
# RUBRIC_PROVIDER_URL=http://model-gateway:9010/v1/rubric
# RUBRIC_PROVIDER_TOKEN=SAME_AS_MODEL_GATEWAY_INTERNAL_TOKEN
# NVD_API_KEY=OPTIONAL_SECRET

# Model gateway. Select exactly one upstream. Production startup fails if the
# selected provider's required values are absent.
# MODEL_GATEWAY_INTERNAL_TOKEN=REQUIRED_RANDOM_SECRET_AT_LEAST_32_CHARS
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=REQUIRED_SECRET
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.6-sol
# For Claude, set MODEL_PROVIDER=anthropic and fill the three values below.
# ANTHROPIC_API_KEY=REQUIRED_SECRET
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=REQUIRED_STRUCTURED_OUTPUTS_COMPATIBLE_MODEL_ID
# ANTHROPIC_VERSION=2023-06-01
# MODEL_GATEWAY_GENERATION_TIMEOUT_MS=1200000
# MODEL_GATEWAY_GENERATION_MAX_ATTEMPTS=1
# Local one-request diagnosis only; never enable in production.
# MODEL_GATEWAY_DEBUG_RAW_RESPONSE_CAPTURE=local-explicit
# MODEL_GATEWAY_REVIEW_TIMEOUT_MS=25000
# MODEL_GATEWAY_RUBRIC_TIMEOUT_MS=9000
# MODEL_GATEWAY_MAX_CONCURRENCY=8
# RUBRIC_CATALOG_JSON={"incident-analysis-v1":{"policyVersion":"incident-analysis-2026.07","passThreshold":0.7,"criteria":[{"id":"evidence","description":"Uses concrete evidence from the isolated exercise data.","weight":0.6},{"id":"mitigation","description":"Explains a proportionate detection or mitigation action.","weight":0.4}]}}

# Environment builder. JSON values must be supplied as one-line JSON strings.
# BUILDKIT_IMAGE=registry.example.invalid/codegate/buildkit@sha256:REQUIRED_DIGEST
# BASE_IMAGE_ALLOWLIST_JSON=["registry.example.invalid/codegate/target-bases/http-v1@sha256:REQUIRED_DIGEST"]
# OUTPUT_REPOSITORY_ALLOWLIST_JSON=["registry.example.invalid/codegate/labs"]
# PACKAGE_CATALOG_JSON={"codegate-http-target@1.0.0":{"imageRef":"registry.example.invalid/codegate/catalog/http-target@sha256:REQUIRED_DIGEST","sourcePath":"/opt/codegate/package/","destination":"/opt/codegate/packages/codegate-http-target/","runtimeKind":"declarative-http-v1"}}
# ARTIFACT_CATALOG_JSON={"REQUIRED_64_CHARACTER_LOWERCASE_SHA256":{"url":"https://artifacts.example.invalid/codegate/catalog/fixture.ndjson"}}
# Catalog base/helper images implement http-v1: UID/GID 65532, read-only root,
# only /tmp writable, HTTP :8080 on 0.0.0.0, /health and /version endpoints.
# BUILD_REGISTRY_SECRET_NAMESPACE=codegate-platform
# BUILD_REGISTRY_SECRET_NAME=codegate-build-registry
# BUILD_REGISTRY_TARGET_SECRET=build-registry-auth
# BUILD_EGRESS_CIDRS=REQUIRED_REGISTRY_CIDR,REQUIRED_ARTIFACT_MIRROR_CIDR
# BUILD_EGRESS_PORTS=443
# BUILD_TIMEOUT_SECONDS=900
# BUILD_JOB_TTL_SECONDS=600
# BUILD_CPU_REQUEST=500m
# BUILD_CPU_LIMIT=2
# BUILD_MEMORY_REQUEST=1Gi
# BUILD_MEMORY_LIMIT=4Gi
# BUILD_EPHEMERAL_STORAGE_LIMIT=12Gi
# RECONCILE_INTERVAL_MS=5000
# BUILDER_ID=https://codegate.ai/builders/environment-builder/v1

# Validator, grader and telemetry data plane.
# COSIGN_PUBLIC_KEY_PATH=/etc/codegate-validator/trust/cosign.pub
# VALIDATOR_CACHE_DIR=/var/cache/codegate-validator
# SANDBOX_RUNNER_URL=http://codegate-runtime.codegate-runtime-system.svc.cluster.local:9000
# ELASTICSEARCH_URL=https://elasticsearch.example.invalid:9200
# ELASTICSEARCH_API_KEY=REQUIRED_SERVICE_SCOPED_KEY

# KubeVirt runtime.
# RUNTIME_MODE=kubevirt
# UBUNTU_DESKTOP_IMAGE=registry.example.invalid/codegate/ubuntu-desktop@sha256:REQUIRED_DIGEST
# KALI_DESKTOP_IMAGE=registry.example.invalid/codegate/kali-desktop@sha256:REQUIRED_DIGEST
# RUNTIME_READY_TIMEOUT_SECONDS=600
# OPENVPN_GATEWAY_IMAGE=registry.example.invalid/codegate/openvpn-gateway@sha256:REQUIRED_DIGEST
# OPENVPN_GATEWAY_BASE_DOMAIN=vpn-runs.example.invalid
# OPENVPN_ISSUER_URL=http://openvpn-issuer.codegate-vpn-system.svc.cluster.local:9100
# OPENVPN_ALLOWED_CIDR=10.42.0.0/16
# SANDBOX_PROBE_IMAGE=registry.example.invalid/codegate/probe-runner@sha256:REQUIRED_DIGEST
# SANDBOX_TIMEOUT_SECONDS=300
# SANDBOX_EXTERNAL_PROBE_HOST=1.1.1.1
# SANDBOX_EXTERNAL_PROBE_PORT=443
# SANDBOX_CANARY_NAMESPACE=codegate-runtime-system
# SANDBOX_CANARY_SERVICE=validation-canary
# SANDBOX_CANARY_PORT=8080

# Real local browser desktops (Windows Docker Desktop / Linux Docker Engine).
# This executor is development-only and supports browser_desktop, not OpenVPN.
# RUNTIME_MODE=docker
# LOCAL_DESKTOP_NETWORK=codegate-local-desktops
# LOCAL_UBUNTU_DESKTOP_IMAGE=lscr.io/linuxserver/webtop:ubuntu-xfce
# LOCAL_KALI_DESKTOP_IMAGE=lscr.io/linuxserver/kali-linux:latest
# LOCAL_TARGET_IMAGE=codegate/local-target:development
# LOCAL_DESKTOP_MEMORY=4g
# LOCAL_DESKTOP_CPUS=2
# LOCAL_DESKTOP_PIDS_LIMIT=1024
# LOCAL_DESKTOP_SHM_SIZE=1g
# LOCAL_TARGET_MEMORY=512m
# LOCAL_TARGET_CPUS=1
# LOCAL_TARGET_PIDS_LIMIT=256
# LOCAL_RUNTIME_CLEANUP_INTERVAL_MS=60000

# Desktop gateway.
# PLATFORM_API_URL=http://codegate-api.codegate-platform.svc.cluster.local:8080
# DESKTOP_UPSTREAM_PORT=6080
# DESKTOP_SESSION_SIGNING_KEY=REQUIRED_RANDOM_SECRET_AT_LEAST_32_CHARS
# DESKTOP_CLIENT=novnc
# DESKTOP_PRESERVE_UPSTREAM_PATH=false
# DESKTOP_COOKIE_SECURE=true
# DESKTOP_SESSION_MAX_MINUTES=1440

# OpenVPN issuer. PKI paths point to read-only Secret mounts.
# OPENVPN_MODE=issuer
# OPENVPN_MASTER_KEY=REQUIRED_32_BYTE_BASE64_KEY
# OPENVPN_ALLOWED_CIDR=10.42.0.0/16
# OPENVPN_CLIENT_CIDR=10.203.0.0/24
# OPENVPN_PROFILE_TTL_MAX_MINUTES=240
# OPENVPN_CA_CERT_PATH=/etc/openvpn/pki/ca.crt
# OPENVPN_CA_KEY_PATH=/etc/openvpn/pki/ca.key
# OPENVPN_TLS_CRYPT_PATH=/etc/openvpn/pki/tls-crypt.key
# OPENVPN_WORK_DIR=/run/openvpn
